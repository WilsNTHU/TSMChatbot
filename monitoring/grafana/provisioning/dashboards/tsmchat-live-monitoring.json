{
  "uid": "tsmchat-live",
  "title": "TSMChat - Live Monitoring",
  "tags": [
    "tsmchat"
  ],
  "timezone": "browser",
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "User Access Rate",
      "description": "Number of user requests hitting TSMChat per second",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{route!=\"/health\",route!=\"/metrics\"}[1m]))",
          "legendFormat": "Access Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Website Response Rate",
      "description": "How quickly TSMChat responds to users — lower is better",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{route!=\"/health\",route!=\"/metrics\"}[1m])) by (le))",
          "legendFormat": "Typical (P50)",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{route!=\"/health\",route!=\"/metrics\"}[1m])) by (le))",
          "legendFormat": "Slow (P95)",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{route!=\"/health\",route!=\"/metrics\"}[1m])) by (le))",
          "legendFormat": "Worst Case (P99)",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Typical (P50)" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "green" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Slow (P95)" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "yellow" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Worst Case (P99)" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "blue" }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 3,
      "title": "Total Page Loads",
      "description": "Frontend page loads reported via /api/metrics/page-load (excludes health checks and scrapes)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(page_load_duration_seconds_count)",
          "legendFormat": "Page Loads",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Live Connections",
      "description": "WebSocket connections across all backend pods",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 8
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "max(websocket_connections_active)",
          "legendFormat": "Connected",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Users Online",
      "description": "Users with an active TSMChat tab (presence). Connected sockets may be higher if tabs are in background.",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 8
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "max(users_online_total)",
          "legendFormat": "Online",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Total Messages",
      "description": "All messages stored in TSMChat — every user, chat, group, and history (Cassandra)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "max(messages_stored_total)",
          "legendFormat": "Total Messages",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "purple",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Active Alerts",
      "description": "Major user-facing issues firing right now: site down, slow responses, high error rate, slow page loads. 0 = healthy.",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 8
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\", alertname=~\"BackendDown|HighErrorRate|HighLatencyP95|HighLatencyP99|SlowPageLoad\"}) or vector(0)",
          "legendFormat": "Active Alerts",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Error Rate",
      "description": "Percentage of API requests returning 5xx errors (excludes health checks)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 8
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\",route!=\"/health\",route!=\"/metrics\"}[5m])) / sum(rate(http_requests_total{route!=\"/health\",route!=\"/metrics\"}[5m])) * 100 or vector(0)",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Live Users & Connections Over Time",
      "description": "Real-time view of how many users are connected to TSMChat",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "max(websocket_connections_active)",
          "legendFormat": "Live Connections",
          "refId": "A"
        },
        {
          "expr": "max(users_online_total)",
          "legendFormat": "Users Online",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Alert Status (Active Alerts)",
      "description": "Firing alerts from AlertManager — green means healthy, red means issues detected",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "ALERTS{alertstate=\"firing\"}",
          "legendFormat": "{{alertname}}",
          "refId": "A"
        },
        {
          "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)",
          "legendFormat": "Total Firing Alerts",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "bars"
          }
        }
      }
    },
    {
      "id": 11,
      "title": "Server CPU Usage",
      "description": "How hard the server is working",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(process_cpu_user_seconds_total[1m])) * 100",
          "legendFormat": "App CPU %",
          "refId": "A"
        },
        {
          "expr": "sum(rate(process_cpu_system_seconds_total[1m])) * 100",
          "legendFormat": "System CPU %",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "id": 12,
      "title": "Server Memory Usage",
      "description": "How much memory the backend is using",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(process_resident_memory_bytes) / 1024 / 1024",
          "legendFormat": "Total Memory (MB)",
          "refId": "A"
        },
        {
          "expr": "sum(nodejs_heap_size_used_bytes) / 1024 / 1024",
          "legendFormat": "Used Memory (MB)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 13,
      "title": "Page Load Speed",
      "description": "How fast the frontend loads for users",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(page_load_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "Typical Load (P50)",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(page_load_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "Slow Load (P95)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          }
        }
      }
    },
    {
      "id": 14,
      "title": "Messaging Activity",
      "description": "Rate of messages being sent across TSMChat",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(messages_sent_total[1m]))",
          "legendFormat": "Messages per second",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 25
          }
        }
      }
    },
    {
      "id": 15,
      "title": "Server Responsiveness (Event Loop)",
      "description": "Lower is better — shows if the server is overwhelmed",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 36
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(nodejs_eventloop_lag_seconds)",
          "legendFormat": "Server Lag",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          }
        }
      }
    },
    {
      "id": 16,
      "title": "Active Tasks (Handles & Requests)",
      "description": "Internal tasks the server is processing — spikes during high traffic",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 36
      },
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(nodejs_active_handles_total)",
          "legendFormat": "Open Connections",
          "refId": "A"
        },
        {
          "expr": "sum(nodejs_active_requests_total)",
          "legendFormat": "Pending Requests",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          }
        }
      }
    }
  ],
  "schemaVersion": 39
}