PORT=3000
NODE_ENV=development

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=tsmchat
PG_PASSWORD=tsmchat_secret
PG_DATABASE=tsmchat

# Cassandra
CASSANDRA_HOSTS=localhost
CASSANDRA_PORT=9042
CASSANDRA_DATACENTER=datacenter1
CASSANDRA_KEYSPACE=tsmchat

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT — change in production
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Google OAuth — create at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# CORS
CORS_ORIGIN=http://localhost:5173

# Alertmanager webhook (required in production)
# ALERT_WEBHOOK_SECRET=change-me-to-a-long-random-webhook-secret

# OpenAI Chat Agent — get API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-nano

# Agent context — all rooms (1v1 + groups); unlimited questions per user
# AGENT_MESSAGES_PER_ROOM=50
# AGENT_MESSAGES_FOCUS_ROOM=80
# AGENT_MAX_CONTEXT_CHARS=48000
# AGENT_MAX_CONTEXT_CHARS_FULL=120000
# gpt-4.1-nano list prices per 1M tokens
# AGENT_INPUT_PRICE_PER_1M=0.10
# AGENT_OUTPUT_PRICE_PER_1M=0.40
